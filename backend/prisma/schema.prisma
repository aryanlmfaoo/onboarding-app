// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String @id @default(uuid(7))
  name        String
  logoUrl     String
  description String
  ownerId     String @unique

  employees User[]
  projects  Project[]

  admissionTokens admissionTokens[]

  documents documentMetaData[]

  projectEmployees ProjectEmployee[]
}

model User {
  id                String @id @default(uuid(7))
  profilePictureUrl String
  firstName         String
  lastName          String
  email             String @unique
  passwordHash      String

  organizationId String?
  level          EMPLOYEE_LEVEL?

  organization Organization? @relation(fields: [organizationId], references: [id])

  tokens jwtTokens[]

  projects Project[]

  documentsUploaded documentMetaData[]

  employeeProjects ProjectEmployee[] @relation("EmployeeProjects")

  employeesUserAddedToProjects ProjectEmployee[] @relation("AddedProjects")
}

model Project {
  id String @id @default(uuid(7))

  name           String
  description    String
  organizationId String
  ownerId        String

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation(fields: [ownerId], references: [id])

  members ProjectEmployee[]

  documents documentMetaData[]

  createdAt DateTime @default(now())
}

model ProjectEmployee {
  employeeId     String
  projectId      String
  organizationId String
  addedBy        String

  level PROJECT_EMPLOYEE_LEVEL

  project Project      @relation(fields: [projectId], references: [id])
  org     Organization @relation(fields: [organizationId], references: [id])

  employee       User @relation("EmployeeProjects", fields: [employeeId], references: [id])
  personWhoAdded User @relation("AddedProjects", fields: [addedBy], references: [id])

  @@id([employeeId, projectId])
}

model jwtTokens {
  id               String @id @default(uuid())
  userId           String @unique
  Employee         User   @relation(fields: [userId], references: [id])
  refreshTokenHash String
}

model admissionTokens {
  id              String         @id @default(uuid())
  organizationId  String
  token           String         @unique @default(uuid(7))
  permissionLevel EMPLOYEE_LEVEL
  expiresAt       DateTime

  org Organization @relation(fields: [organizationId], references: [id])
}

model documentMetaData {
  id             String @id @default(uuid())
  organizationId String
  projectId      String

  filename   String
  objectKey  String      @unique
  mimeType   String
  fileSize   Int
  status     FILE_STATUS @default(NOTUPLOADED)
  uploadedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [organizationId], references: [id])
  project  Project      @relation(fields: [projectId], references: [id])
  uploader User         @relation(fields: [uploadedBy], references: [id])
}

enum EMPLOYEE_LEVEL {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum PROJECT_EMPLOYEE_LEVEL {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum FILE_STATUS {
  NOTUPLOADED
  PROCESSED
  UNPROCESSED
  FAILED
  PROCESSING
}
