// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String @id @default(uuid(7))
  name        String
  logoUrl     String
  description String
  ownerId     String

  employees User[]
  projects  Project[]

  admissionTokens admissionTokens[]
}

model User {
  id                String @id @default(uuid(7))
  profilePictureUrl String
  firstName         String
  lastName          String
  email             String @unique
  passwordHash      String

  organizationId String?
  level          EMPLOYEE_LEVEL?

  organization Organization? @relation(fields: [organizationId], references: [id])

  projectMemberships ProjectEmployee[]

  tokens jwtTokens[]
}

model Project {
  id String @id @default(uuid(7))

  name           String
  description    String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  members ProjectEmployee[]
}

model ProjectEmployee {
  employeeId String
  projectId  String

  level PROJECT_EMPLOYEE_LEVEL

  employee User    @relation(fields: [employeeId], references: [id])
  project  Project @relation(fields: [projectId], references: [id])

  @@id([employeeId, projectId])
  @@unique([employeeId, projectId])
}

model jwtTokens {
  id               String @id @default(uuid())
  userId           String @unique
  Employee         User   @relation(fields: [userId], references: [id])
  refreshTokenHash String
}

model admissionTokens {
  id              String         @id @default(uuid())
  organizationId  String
  token           String         @unique @default(uuid(7))
  permissionLevel EMPLOYEE_LEVEL
  expiresAt       DateTime

  org Organization @relation(fields: [organizationId], references: [id])
}

enum EMPLOYEE_LEVEL {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum PROJECT_EMPLOYEE_LEVEL {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}
